# Azure DevOps
AZURE_ORG=sua-organizacao
AZURE_PROJECT=seu-projeto
AZURE_PAT=seu-personal-access-token

# Gemini
GEMINI_API_KEY=sua-chave-aqui
LLM_MODEL=gemini-2.5-flash

# Rate limiting: requests por minuto (free tier: ~10 RPM | com billing: ~30 RPM)
LLM_RPM=10

# Retry para erros transientes (503/429 do Gemini podem durar minutos)
# LLM_MAX_RETRIES=8        # tentativas antes de desistir
# LLM_RETRY_BASE_DELAY=15  # delay inicial em segundos (dobra a cada tentativa)
# LLM_RETRY_MAX_DELAY=120  # teto do backoff em segundos

# Fallback: modelo alternativo quando o modelo primário fica sobrecarregado (503)
# LLM_FALLBACK_MODEL=gemini-1.5-flash
# LLM_FALLBACK_AFTER=3

# Logging (DEBUG para ver payloads, INFO para normal)
LOG_LEVEL=INFO
