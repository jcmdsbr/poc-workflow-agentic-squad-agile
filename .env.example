# Azure DevOps
AZURE_ORG=sua-organizacao
AZURE_PROJECT=seu-projeto
AZURE_PAT=seu-personal-access-token

# ── LLM ── Troque apenas LLM_MODEL e a key correspondente
# Ollama local:  LLM_MODEL=ollama/llama3.1
# Gemini:        LLM_MODEL=gemini/gemini-2.0-flash  (precisa de GEMINI_API_KEY)
# OpenAI:        LLM_MODEL=openai/gpt-4o            (precisa de OPENAI_API_KEY)
LLM_MODEL=ollama/llama3.1

# Keys de providers hospedados (descomente o que usar)
# GEMINI_API_KEY=sua-chave-aqui
# OPENAI_API_KEY=sua-chave-aqui

# Ollama tuning (só usado quando LLM_MODEL=ollama/*)
LLM_NUM_CTX=32768

# Rate limiting: requests por minuto (0 = sem limite, ex: Ollama local)
# Free tier Gemini: ~10 RPM | Com billing: ~30 RPM
LLM_RPM=10

# Retry para erros transientes (503/429 do Gemini podem durar minutos)
# LLM_MAX_RETRIES=6        # tentativas antes de desistir
# LLM_RETRY_BASE_DELAY=10  # delay inicial em segundos  (dobra a cada tentativa)
# LLM_RETRY_MAX_DELAY=60   # teto do backoff em segundos

# CrewAI Tracing (envia dados para app.crewai.com)
CREWAI_TRACING_ENABLED=false

# Logging (DEBUG para ver payloads, INFO para normal)
LOG_LEVEL=INFO
